# Discord Bot Token (required — set this in Railway → Variables)
DISCORD_TOKEN=your_bot_token_here

# Required for instant slash commands on Railway (right-click server icon → Copy Server ID)
DISCORD_GUILD_ID=123456789012345678

# Optional: SQLite file path (mount a Railway volume at /app/data for persistence)
# DATABASE_PATH=/app/data/bot_data.db
